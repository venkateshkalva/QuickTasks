using System.Net;
using System.Net.Mail;
using WeedKillerSendGridAPI.Models;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Options;

namespace WeedKillerSendGridAPI.Services;

public interface IEmailNotificationService
{
    Task SendFailureAlertAsync(int offset, string startDate, string endDate, Exception ex);
}

public class EmailNotificationService : IEmailNotificationService
{
    private readonly AppSettings _settings;
    private readonly ILogger<EmailNotificationService> _logger;

    public EmailNotificationService(IOptions<AppSettings> settings, ILogger<EmailNotificationService> logger)
    {
        _settings = settings.Value;
        _logger = logger;
    }

    public async Task SendFailureAlertAsync(int offset, string startDate, string endDate, Exception ex)
    {
        try
        {
            var smtp = _settings.Smtp;

            using var client = new SmtpClient(smtp.Host, smtp.Port)
            {
                EnableSsl = smtp.EnableSsl,
                Credentials = new NetworkCredential(smtp.Username, smtp.Password)
            };

            var subject = $"[WeedKillerSendGridAPI] ❌ Failure at Offset {offset}";

            var body = $"""
                WeedKillerSendGridAPI encountered a failure during paginated fetch.

                ── Checkpoint Details ──────────────────────────────
                  Offset     : {offset}
                  Start Date : {startDate}
                  End Date   : {endDate}
                ────────────────────────────────────────────────────

                To resume, update appsettings.json:
                  "StartOffset" : {offset}
                  "StartDate"   : "{startDate}"
                  "EndDate"     : "{endDate}"

                ── Error Details ────────────────────────────────────
                  Message    : {ex.Message}
                  Type       : {ex.GetType().FullName}
                  StackTrace :
                {ex.StackTrace}
                ────────────────────────────────────────────────────

                Timestamp (UTC): {DateTime.UtcNow:yyyy-MM-dd HH:mm:ss}
                """;

            var mail = new MailMessage
            {
                From       = new MailAddress(smtp.From),
                Subject    = subject,
                Body       = body,
                IsBodyHtml = false
            };

            foreach (var recipient in smtp.To)
                mail.To.Add(recipient);

            await client.SendMailAsync(mail);

            _logger.LogInformation("Failure alert email sent to {Recipients}.", string.Join(", ", smtp.To));
        }
        catch (Exception emailEx)
        {
            // Never let email failure crash the app — just log it
            _logger.LogError(emailEx, "Failed to send failure alert email.");
        }
    }
}




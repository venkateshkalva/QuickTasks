public IActionResult OnPostEditCQ(int CQID)
{
    var searchCriteria = Set_ClaimantSearchCriteria as Dictionary<String, String> 
                         ?? new Dictionary<String, String>();

    searchCriteria["CQID"] = CQID.ToString();
    
    this.Set_ClaimantSearchCriteria = searchCriteria;
    
    return RedirectToPage(PagePaths.CQDetails, 
        new { pid = ClaimantID, sdqid = CQID.ToString() });
}

using WeedKillerSendGridAPI.Models;
using WeedKillerSendGridAPI.Services;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Options;

namespace WeedKillerSendGridAPI;

public class BounceProcessor
{
    private readonly IBounceApiService _apiService;
    private readonly IDatabaseService _dbService;
    private readonly IEmailNotificationService _emailService;
    private readonly AppSettings _settings;
    private readonly ILogger<BounceProcessor> _logger;

    public BounceProcessor(
        IBounceApiService apiService,
        IDatabaseService dbService,
        IEmailNotificationService emailService,
        IOptions<AppSettings> settings,
        ILogger<BounceProcessor> logger)
    {
        _apiService   = apiService;
        _dbService    = dbService;
        _emailService = emailService;
        _settings     = settings.Value;
        _logger       = logger;
    }

    public async Task RunAsync(CancellationToken ct = default)
    {
        await _dbService.EnsureTableExistsAsync(ct);

        // Allow resuming from a known offset (e.g. after a failure)
        int offset     = _settings.StartOffset;
        int page       = 1;
        int totalSaved = 0;

        _logger.LogInformation(
            "=== Starting paginated sync | StartOffset: {Offset} | Limit: {Limit} | {Start} → {End} ===",
            offset, _settings.PageLimit, _settings.StartDate, _settings.EndDate);

        while (true)
        {
            List<BounceRecord> records;

            // ── 1. Fetch one page ────────────────────────────────────────────
            try
            {
                _logger.LogInformation("[Page {Page}] Fetching offset={Offset}...", page, offset);
                records = await _apiService.FetchPageAsync(offset, ct);
                _logger.LogInformation("[Page {Page}] Received {Count} record(s).", page, records.Count);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "[Page {Page}] API fetch FAILED at offset={Offset}. Sending alert...", page, offset);
                await _emailService.SendFailureAlertAsync(offset, _settings.StartDate, _settings.EndDate, ex);
                throw;
            }

            // ── 2. Insert this page immediately ─────────────────────────────
            if (records.Count > 0)
            {
                try
                {
                    var saved = await _dbService.SaveBounceRecordsAsync(records, ct);
                    totalSaved += saved;
                    _logger.LogInformation(
                        "[Page {Page}] Inserted {Saved} record(s). Running total: {Total}.",
                        page, saved, totalSaved);
                }
                catch (Exception ex)
                {
                    _logger.LogError(ex, "[Page {Page}] DB insert FAILED at offset={Offset}. Sending alert...", page, offset);
                    await _emailService.SendFailureAlertAsync(offset, _settings.StartDate, _settings.EndDate, ex);
                    throw;
                }
            }
            else
            {
                _logger.LogWarning("[Page {Page}] No records returned at offset={Offset}.", page, offset);
            }

            // ── 3. Check if this was the last page ───────────────────────────
            if (records.Count < _settings.PageLimit)
            {
                _logger.LogInformation(
                    "[Page {Page}] Last page reached ({Count} < limit {Limit}). Stopping.",
                    page, records.Count, _settings.PageLimit);
                break;
            }

            // ── 4. Advance to the next page ──────────────────────────────────
            offset += _settings.PageLimit;
            page++;
        }

        _logger.LogInformation("=== Sync complete. Total records inserted: {Total} ===", totalSaved);
    }
}



